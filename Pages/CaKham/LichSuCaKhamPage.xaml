<Page x:Class="WPF.Pages.CaKham.LichSuCaKhamPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="#F5F7FA"
      FontFamily="Palatino Linotype" FontSize="16"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch">
    <Grid Focusable="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ================= HEADER ================= -->
            <Border Grid.Row="0" Background="White" CornerRadius="15" Padding="10" Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <DatePicker x:Name="dtpDate" Height="45" Margin="10,0" Padding="12,6" FontSize="15" SelectedDateFormat="Short" 
                                    Language="vi-VN" Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                    materialDesign:HintAssist.Hint="Ngày khám" materialDesign:TextFieldAssist.TextFieldCornerRadius="20" SelectedDateChanged="dtpDate_SelectedDateChanged"/>
                    </StackPanel>
                    <!-- ACTION -->

                    <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="10,0,0,0" HorizontalAlignment="Right">
                        <ComboBox x:Name="cbCategory" Width="100" Height="30" Margin="5,0" Style="{StaticResource MaterialDesignDataGridComboBox}" SelectionChanged="cbCategory_SelectionChanged"/>
                        <ComboBox x:Name="cboStatus" Width="200" Height="30" Margin="5,0" Style="{StaticResource MaterialDesignDataGridComboBox}" SelectionChanged="cboStatus_SelectionChanged"/>
                        <Button Click="Refresh_Click"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="15"
                                Margin="5,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh"/>
                                <TextBlock Text="Refresh" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <!-- ================= CONTENT ================= -->
            <Border Grid.Row="1" Margin="10" Padding="3"
                    Background="White" CornerRadius="10">
                <Grid>

                    <!-- DATA GRID -->
                    <DataGrid x:Name="GridContent"
                              ItemsSource="{Binding Items}"
                              HeadersVisibility="Column"/>

                    <!-- EMPTY -->
                    <TextBlock Text="Không có dữ liệu"
                   Foreground="#9CA3AF"
                   FontStyle="Italic"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </Grid>
            </Border>

            <!-- ================= FOOTER ================= -->
            <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="10" Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="Kích thước trang:" Padding="8" Margin="10"/>
                        <TextBox x:Name="txtSizepage" KeyDown="SizePage_KeyDown" LostFocus="SizePage_LostFocus"
                                 Width="30" Height="30" Padding="5,0" Margin="-10"
                                 VerticalAlignment="Center" HorizontalAlignment="Center"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding SizePage}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">

                        <Button Click="First_Click" Margin="2" Background="#E0E7FF"
                            IsEnabled="{Binding CanGoPrev}"                            >
                            <materialDesign:PackIcon Kind="PageFirst" Foreground="#01050F"/>
                        </Button>

                        <Button Click="Prev_Click" Margin="2" Background="#E0E7FF"
                            IsEnabled="{Binding CanGoPrev}">
                            <materialDesign:PackIcon Kind="ChevronLeft" Foreground="#01050F"/>
                        </Button>

                        <TextBlock Text="{Binding PageDisplay}" Margin="10" Padding="10" Foreground="#01050F"/>

                        <Button Click="Next_Click" Margin="2" Background="#E0E7FF"
                            IsEnabled="{Binding CanGoNext}">
                            <materialDesign:PackIcon Kind="ChevronRight" Foreground="#01050F"/>
                        </Button>

                        <Button Click="Last_Click" Margin="2" Background="#E0E7FF"
                            IsEnabled="{Binding CanGoNext}">
                            <materialDesign:PackIcon Kind="PageLast" Foreground="#01050F"/>
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <!-- ================= LOADING ================= -->
        <Grid Background="#66000000"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">

            <materialDesign:PackIcon Kind="Loading" Width="150" Height="150" Foreground="White" 
                HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                <materialDesign:PackIcon.RenderTransform>
                    <RotateTransform x:Name="SpinnerRotate"/>
                </materialDesign:PackIcon.RenderTransform>
            </materialDesign:PackIcon>

            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                             Storyboard.TargetProperty="Angle"
                                             From="0" To="360"
                                             Duration="0:0:1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
        </Grid>

    </Grid>
</Page>