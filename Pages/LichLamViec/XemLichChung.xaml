<Page x:Class="WPF.Pages.LichLamViec.XemLichChung"
      xmlns:conv="clr-namespace:WPF.Common"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="#F5F7FA"
      FontFamily="Palatino Linotype" FontSize="16"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:GreaterThanOneConverter x:Key="GreaterThanOneConverter"/>
    </Page.Resources>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tuần chọn + Refresh -->
            <StackPanel Orientation="Horizontal" Margin="10" Grid.Row="0" VerticalAlignment="Center">
                <ComboBox x:Name="cbWeek" Width="200" SelectionChanged="cbWeek_SelectionChanged" DisplayMemberPath="Display" SelectedValuePath="Page" SelectedIndex="0"/>
            </StackPanel>

            <!-- Nội dung lịch -->
            <Grid Grid.Row="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header ngày -->
                    <RowDefinition Height="Auto"/> <!-- Ca sáng label -->
                    <RowDefinition Height="*"/>    <!-- Ca sáng -->
                    <RowDefinition Height="Auto"/> <!-- Ca chiều label -->
                    <RowDefinition Height="*"/>    <!-- Ca chiều -->
                </Grid.RowDefinitions>

                <!-- Header ngày -->
                <ItemsControl x:Name="icHeader" Grid.Row="0" Margin="0,0,0,5">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#E0E7FF" CornerRadius="5" Margin="1" Padding="4">
                                <TextBlock Text="{Binding}" FontWeight="Bold" TextAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Ca sáng -->
                <TextBlock Text="Ca sáng" FontWeight="Bold" Grid.Row="1" Margin="0,5,0,5"/>
                <ItemsControl x:Name="icMorning" Grid.Row="2">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Color}" CornerRadius="5" Margin="1" Padding="6" MinHeight="100">
                                <ItemsControl ItemsSource="{Binding NhanViens}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="2" Padding="5" CornerRadius="6" Background="#E0E7FF" BorderBrush="#00000020" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" FontSize="12">
                                                        <Run Text="{Binding NhanVien.Name}"/>
                                                    </TextBlock>

                                                    <TextBlock FontSize="11" Foreground="#444">
                                                        <Run Text="{Binding ChucVu}"/>
                                                        <Run Text=" • "/>
                                                        <Run Text="{Binding TenPhong}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Ca chiều -->
                <TextBlock Text="Ca chiều" FontWeight="Bold" Grid.Row="3" Margin="0,10,0,5"/>
                <ItemsControl x:Name="icAfternoon" Grid.Row="4">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Color}" CornerRadius="5" Margin="1" Padding="6" MinHeight="100">
                                <ItemsControl ItemsSource="{Binding NhanViens}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="2" Padding="5" CornerRadius="6" Background="#E0E7FF" BorderBrush="#00000020" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" FontSize="12">
                                                        <Run Text="{Binding NhanVien.Name}"/>
                                                    </TextBlock>

                                                    <TextBlock FontSize="11" Foreground="#444">
                                                        <Run Text="{Binding ChucVu}"/>
                                                        <Run Text=" • "/>
                                                        <Run Text="{Binding TenPhong}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- Navigation tuần -->
            <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="10" Margin="10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Click="First_Click" Margin="2" Background="#E0E7FF" IsEnabled="{Binding CanGoPrev}">
                        <materialDesign:PackIcon Kind="PageFirst" Foreground="#01050F"/>
                    </Button>

                    <Button Click="Prev_Click" Margin="2" Background="#E0E7FF" IsEnabled="{Binding CanGoPrev}">
                        <materialDesign:PackIcon Kind="ChevronLeft" Foreground="#01050F"/>
                    </Button>

                    <Button Click="Next_Click" Margin="2" Background="#E0E7FF" IsEnabled="{Binding CanGoNext}">
                        <materialDesign:PackIcon Kind="ChevronRight" Foreground="#01050F"/>
                    </Button>

                    <Button Click="Last_Click" Margin="2" Background="#E0E7FF" IsEnabled="{Binding CanGoNext}">
                        <materialDesign:PackIcon Kind="PageLast" Foreground="#01050F"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Loading overlay -->
        <Grid Background="#66000000" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <materialDesign:PackIcon Kind="Loading" Width="150" Height="150" Foreground="White"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                <materialDesign:PackIcon.RenderTransform>
                    <RotateTransform x:Name="SpinnerRotate"/>
                </materialDesign:PackIcon.RenderTransform>
            </materialDesign:PackIcon>

            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                             Storyboard.TargetProperty="Angle"
                                             From="0" To="360"
                                             Duration="0:0:1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
        </Grid>
    </Grid>
</Page>