<Page x:Class="WPF.Pages.LichLamViec.NhapLichLamViec"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:conv="clr-namespace:WPF.Common"
      FontFamily="Palatino Linotype">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <!-- ================= MAIN LAYOUT ================= -->
        <Border BorderBrush="#D7E6F2" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <!-- HEADER: Chọn file / sheet -->
                <Border Grid.Row="0" Background="White">
                    <StackPanel Margin="10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0">
                            <TextBox x:Name="txtFile" Width="450" Height="32" IsReadOnly="True" VerticalContentAlignment="Center"/>
                            <Button Width="90" Height="32" Margin="10" Click="btnChooseFile_Click" BorderBrush="White"
                                    Style="{StaticResource MaterialDesignRaisedButton}" Background="#028BDF">
                                Chọn file
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0">
                            <TextBlock Text="Sheet:" Width="60" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cbSheet" Width="250" Height="30"/>
                            <Button Width="90" Height="30" Margin="10" Click="btnPreview_Click" BorderBrush="White"
                                    Style="{StaticResource MaterialDesignRaisedButton}" Background="#028BDF">
                                Preview
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- DATA PREVIEW -->
                <Border Grid.Row="1" Background="White" Margin="10,5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="txtSummary" Foreground="Gray" Margin="0,5" Grid.Row="0"/>
                        <DataGrid x:Name="gridPreview" AutoGenerateColumns="True" CanUserAddRows="False" CanUserDeleteRows="False"
                                  IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow" RowBackground="White"
                                  AlternatingRowBackground="#F7F7F7" ColumnWidth="*" Grid.Row="1"/>
                    </Grid>
                </Border>

                <!-- ERROR LIST -->
                <Border Grid.Row="2" Background="White" Margin="10,5" Padding="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Lỗi:" Foreground="Gray" Margin="0,0,0,5" Grid.Row="0"/>
                        <ListBox x:Name="lstErrors" Foreground="Red" Grid.Row="1"/>
                    </Grid>
                </Border>

                <!-- FOOTER -->
                <Border Grid.Row="3" Background="#DEE5E9">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0">
                        <Button x:Name="btnValidate" Click="btnValidate_Click" Width="100" Height="40"
                                BorderBrush="#028BDF" Background="White" Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="22" Margin="5,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2">
                                <TextBlock Text="Kiểm tra" HorizontalAlignment="Center" Foreground="Black"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnLuu" Click="btnLuu_Click" Width="70" Height="40"
                                BorderBrush="White" Background="#028BDF"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                materialDesign:ButtonAssist.CornerRadius="20">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2">
                                <TextBlock Text="Lưu" HorizontalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ================= LOADING OVERLAY ================= -->
        <Grid Background="#66000000" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <materialDesign:PackIcon Kind="Loading" Width="150" Height="150" Foreground="White"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     RenderTransformOrigin="0.5,0.5">
                <materialDesign:PackIcon.RenderTransform>
                    <RotateTransform x:Name="SpinnerRotate"/>
                </materialDesign:PackIcon.RenderTransform>
            </materialDesign:PackIcon>

            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                             Storyboard.TargetProperty="Angle"
                                             From="0" To="360"
                                             Duration="0:0:1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
        </Grid>
    </Grid>
</Page>