<Window x:Class="WPF.Windows.CaKham.ViewCaKham" Loaded="ViewCaKham_Loaded"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        FontFamily="Palatino Linotype" FontSize="16" FontWeight="Bold" ResizeMode="NoResize"
        Width="520" Height="470" WindowStartupLocation="CenterScreen" WindowStyle="None">
    <Border BorderBrush="#D7E6F2" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#42A5F5" Padding="16" MouseDown="Header_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="About" Width="50" Height="50" Margin="0,0,10,0" Foreground="White"/>
                    <TextBlock Text="Chi tiết ca khám" FontSize="16" FontWeight="Medium" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="White" IsEnabled="False">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="txtID" Grid.Row="0" Grid.Column="0" Height="45" Margin="10" Padding="12,6"
                             VerticalContentAlignment="Center" Style="{StaticResource MaterialDesignOutlinedTextBox}" IsEnabled="False"
                             materialDesign:HintAssist.Hint="Mã ca khám" materialDesign:TextFieldAssist.TextFieldCornerRadius="20"/>
                    <TextBox x:Name="txtName" Grid.Row="0" Grid.Column="1" Height="45" Margin="10" Padding="12,6"
                             VerticalContentAlignment="Center" Style="{StaticResource MaterialDesignOutlinedTextBox}" IsEnabled="False"
                             materialDesign:HintAssist.Hint="Khung giờ/ Ngày" materialDesign:TextFieldAssist.TextFieldCornerRadius="20"/>
                    <TextBox x:Name="txtUser" Grid.Row="1" Height="45" Margin="10" Padding="12,6"
                             VerticalContentAlignment="Center" Style="{StaticResource MaterialDesignOutlinedTextBox}" IsEnabled="False"
                             materialDesign:HintAssist.Hint="Họ và tên" materialDesign:TextFieldAssist.TextFieldCornerRadius="20"/>
                    <TextBox x:Name="txtStatus" Grid.Row="1" Grid.Column="1" Height="45" Margin="10" Padding="12,6"
                             VerticalContentAlignment="Center" Style="{StaticResource MaterialDesignOutlinedTextBox}" IsEnabled="False"
                             materialDesign:HintAssist.Hint="Trạng Thái" materialDesign:TextFieldAssist.TextFieldCornerRadius="20"/>
                    <TextBox x:Name="txtLyDo" Grid.Row="2" Grid.ColumnSpan="2" Height="45" Margin="10" Padding="12,6"
                             VerticalContentAlignment="Center" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Lý do" materialDesign:TextFieldAssist.TextFieldCornerRadius="20"/>
                    <TextBox x:Name="txtGhiChu" Grid.Row="3" Grid.ColumnSpan="2" Height="45" Margin="10" Padding="12,6"
                             VerticalContentAlignment="Center" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Ghi Chú" materialDesign:TextFieldAssist.TextFieldCornerRadius="20"/>
                    <DatePicker x:Name="dtpRegistration" Grid.Row="4" Grid.Column="0" Height="45" Margin="10" Padding="12,6"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}" materialDesign:HintAssist.Hint="Ngày đăng ký"
                                materialDesign:TextFieldAssist.TextFieldCornerRadius="20"/>
                    <DatePicker x:Name="dtpAppointment" Grid.Row="4" Grid.Column="1" Height="45" Margin="10" Padding="12,6"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}" materialDesign:HintAssist.Hint="Ngày ngày khám"
                                materialDesign:TextFieldAssist.TextFieldCornerRadius="20"/>

                </Grid>
            </Border>
            <!-- Footer -->
            <Border Grid.Row="2" Background="#DEE5E9">
                <StackPanel Orientation ="Horizontal" VerticalAlignment="Center" HorizontalAlignment ="Right" Margin="0,0,10,0">
                    <Button x:Name="btnHuy" Click="btnHuy_Click" Width="70" Height="40" Margin="0,0,10,0"
                           BorderBrush="#E57373" Background="White"
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           materialDesign:ButtonAssist.CornerRadius="20" >
                        <StackPanel Orientation ="Horizontal" HorizontalAlignment ="Center" VerticalAlignment="Center" Margin="2">
                            <TextBlock Text="Đóng" HorizontalAlignment="Center" Foreground="Gray"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>