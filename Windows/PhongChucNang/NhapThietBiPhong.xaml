<Window x:Class="WPF.Windows.PhongChucNang.NhapThietBiPhong"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        FontFamily="Palatino Linotype" FontSize="16" FontWeight="Bold" ResizeMode="NoResize"
        Width="600" Height="680" WindowStartupLocation="CenterScreen" WindowStyle="None">
    <Border BorderBrush="#D7E6F2" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#42A5F5" Padding="16" MouseDown="Header_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="FileExcel" Width="50" Height="50" Margin="0,0,10,0" Foreground="White"/>
                    <TextBlock Text="Nhập thiết bị phòng từ Excel" FontSize="16" FontWeight="Medium" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="White">

                <StackPanel Margin="10">

                    <StackPanel Orientation="Horizontal" Margin="10,0">
                        <TextBox x:Name="txtFile" Width="450" Height="32" IsReadOnly="True" VerticalContentAlignment="Center"/>
                        <Button Width="90" Height="32" Margin="10" Click="btnChooseFile_Click" BorderBrush="White"
                                Style="{StaticResource MaterialDesignRaisedButton}" Background="#028BDF">
                            Chọn file
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,0">
                        <TextBlock Text="Sheet:" Width="60" VerticalAlignment="Center"/>
                        <ComboBox x:Name="cbSheet"  Width="250" Height="30"/>
                        <Button Width="90" Height="30" Margin="10" Click="btnPreview_Click" BorderBrush="White"
                                Style="{StaticResource MaterialDesignRaisedButton}" Background="#028BDF">Preview
                        </Button>
                        <Button Width="90" Height="30" Margin="10" Click="btnValidate_Click" BorderBrush="White"
                                Style="{StaticResource MaterialDesignRaisedButton}" Background="#028BDF"> Validate
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="txtSummary" Foreground="Gray" Margin="0,5"/>
                    <DataGrid x:Name="gridPreview" Height="250" Margin="0,10" AutoGenerateColumns="True"
                              CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                              SelectionMode="Single" SelectionUnit="FullRow" RowBackground="White"
                              AlternatingRowBackground="#F7F7F7" ColumnWidth="*"/>
                    <ListBox x:Name="lstErrors" Foreground="Red" Height="100"/>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#DEE5E9">
                <StackPanel Orientation ="Horizontal" VerticalAlignment="Center" HorizontalAlignment ="Right" Margin="0,0,10,0">
                    <Button x:Name="btnHuy" Click="btnHuy_Click" Width="70" Height="40" Margin="0,0,10,0"
                           BorderBrush="#E57373" Background="White"
                           Style="{StaticResource MaterialDesignOutlinedButton}"
                           materialDesign:ButtonAssist.CornerRadius="20" >
                        <StackPanel Orientation ="Horizontal" HorizontalAlignment ="Center" VerticalAlignment="Center" Margin="2">
                            <TextBlock Text="Hủy" HorizontalAlignment="Center" Foreground="Gray"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnLuu" Click="btnLuu_Click" Width="70" Height="40"
                            BorderBrush="White" Background="#028BDF"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            materialDesign:ButtonAssist.CornerRadius="20">
                        <StackPanel Orientation ="Horizontal" HorizontalAlignment ="Center" VerticalAlignment="Center" Margin="2">
                            <TextBlock Text="Lưu" HorizontalAlignment="Center" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
