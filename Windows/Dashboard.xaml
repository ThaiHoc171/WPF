<Page x:Class="WPF.Windows.Dashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6FB">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- GREETING -->
        <Border Background="White"
                CornerRadius="15"
                Padding="20"
                Margin="0,0,0,10">

            <StackPanel>
                <TextBlock Text="Good Morning, Doctor"
                           FontSize="18"
                           FontWeight="Bold"/>

                <TextBlock Text="Have a nice day at work"
                           Foreground="Gray"/>
            </StackPanel>
        </Border>

        <!-- STATS -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,10,0,0">

            <Border Background="#6C63FF"
                    CornerRadius="15"
                    Margin="5"
                    Padding="15">
                <StackPanel>
                    <TextBlock Text="Total Patients" Foreground="White"/>
                    <TextBlock Text="580"
                               FontSize="20"
                               Foreground="White"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="White"
                    CornerRadius="15"
                    Margin="5"
                    Padding="15">
                <StackPanel>
                    <TextBlock Text="Appointments"/>
                    <TextBlock Text="288"
                               FontSize="20"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="White"
                    CornerRadius="15"
                    Margin="5"
                    Padding="15">
                <StackPanel>
                    <TextBlock Text="Phone Calls"/>
                    <TextBlock Text="356"
                               FontSize="20"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Background="White"
                    CornerRadius="15"
                    Margin="5"
                    Padding="15">
                <StackPanel>
                    <TextBlock Text="Unread Mail"/>
                    <TextBlock Text="05"
                               FontSize="20"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>

        </UniformGrid>
    </Grid>
</Page>