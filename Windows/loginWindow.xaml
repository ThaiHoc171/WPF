<Window x:Class="WPF.Windows.loginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Login"
        Height="600"
        Width="1000"
        FontFamily="Palatino Linotype"
        FontWeight="Bold"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#E9EEF5" Icon="/Assets/Images/System/logo.png">

    <!-- ROOT GRID -->
    <materialDesign:DialogHost
    Identifier="RootDialog"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

        <Grid>

            <!-- ROWS -->
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ================= TOP BAR ================= -->
            <Border Grid.Row="0"
                    Background="White"
                    MouseDown="TopBar_MouseDown">

                <Grid>

                    <TextBlock Text="Hệ thống phòng khám"
                               VerticalAlignment="Center"
                               Margin="12,0"
                               FontSize="14"
                               FontWeight="Bold"/>

                    <Button Width="50"
                            Height="40"
                            HorizontalAlignment="Right"
                            Margin="2,2,0,0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BtnExit_Click">
                                        <materialDesign:PackIcon
                            Kind="Close"
                            Width="20"
                            Height="20"
                            Foreground="Red"/>

                    </Button>

                </Grid>

            </Border>

            <!-- ================= MAIN CONTENT ================= -->
            <Grid Grid.Row="1">

                <!-- COLUMNS -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>


                <!-- LEFT PANEL -->
                <Grid Grid.Column="0" 
                      Background="#1F5FBF">

                    <Border CornerRadius="80"
                            Background="White"
                            Padding="10"
                            Width="320"
                            Height="300"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                        <Border Height="260"
                                Width="260">

                            <Image Source="/Assets/Images/System/logo-text.png"
                                   Stretch="Uniform"/>

                        </Border>

                    </Border>

                </Grid>


                <!-- RIGHT PANEL -->
                <Grid Grid.Column="1" 
                      Background="#FFDFF5F5">
                    <Border Width="350"
                            Padding="40"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Left"
                            CornerRadius="40"
                            Background="White" 
                            Grid.ColumnSpan="2" 
                            Margin="75,83,0,0" 
                            Grid.RowSpan="2">

                        <StackPanel>

                            <TextBlock Text="Đăng nhập"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0 0 0 30"/>

                            <TextBox x:Name="txtEmail"
                                     Height="45"
                                     Margin="0 0 0 10"
                                     Padding="12 6"
                                     VerticalContentAlignment="Center"
                                     FontSize="15"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Email"
                                     materialDesign:TextFieldAssist.TextFieldCornerRadius="20"/>

                            <PasswordBox x:Name="txtPassword"
                                         Height="45"
                                         Margin="0 0 0 10"
                                         Padding="12 6"
                                         VerticalContentAlignment="Center"
                                         FontSize="15"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         KeyDown="Password_KeyDown"
                                         materialDesign:HintAssist.Hint="Password"
                                         materialDesign:TextFieldAssist.TextFieldCornerRadius="20"/>

                            <TextBox x:Name="txtPasswordVisible"
                                     Height="45"
                                     Margin="0 0 0 10"
                                     Padding="12 6"
                                     VerticalContentAlignment="Center"
                                     FontSize="15"
                                     Visibility="Collapsed"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Password"
                                     materialDesign:TextFieldAssist.TextFieldCornerRadius="20"/>

                            <CheckBox x:Name="checkShowPassword"
                                      Content="Hiển thị mật khẩu"
                                      Margin="0 0 0 20"
                                      Checked="checkShowPassword_Checked"
                                      Unchecked="checkShowPassword_Unchecked"/>

                            <Button x:Name="btnLogin"
                                    Content="Đăng nhập"
                                    Height="45"
                                    Margin="0 0 0 10"
                                    FontSize="20"
                                    FontWeight="Bold"
                                    Background="#FF2A8EDA"
                                    BorderBrush="#FF4E4F4F"
                                    Click="btnLogin_Click"
                                    materialDesign:ButtonAssist.CornerRadius="20"/>

                            <Button x:Name="btnAdminSupport"
                                    Content="Liên hệ Admin?"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    FontSize="13"
                                    Foreground="#1976D2"
                                    Cursor="Hand"
                                    FontWeight="Bold"/>

                        </StackPanel>

                    </Border>

                </Grid>

            </Grid>

        </Grid>


    </materialDesign:DialogHost>
</Window>